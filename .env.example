# Team Falcons Pricing Web — environment variables
# Copy to .env.local and fill in the values.

# Supabase (from Settings → API in your Supabase project)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key — SERVER-ONLY. Needed for admin invite + PDF rendering + client portal.
# Get from Supabase → Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Public app URL (for client portal + PDF links)
# In Vercel: set to your custom domain once you swap off *.vercel.app
NEXT_PUBLIC_APP_URL=https://falcons-pricing.vercel.app

# First admin email — the user who bootstraps the system
FIRST_ADMIN_EMAIL=koge@falcons.sa
